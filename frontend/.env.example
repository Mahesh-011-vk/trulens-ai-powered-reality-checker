# ─── TruthLens Frontend Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in values.
# In development, Vite's proxy handles /api → localhost:8000 automatically.
# Only set VITE_API_URL if you're pointing at a remote backend.

# Backend API base URL (leave blank to use the built-in Vite proxy)
VITE_API_URL=
