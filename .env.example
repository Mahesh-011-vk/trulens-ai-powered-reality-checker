# ─── TruthLens Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your keys.
# None of these are required — the app has fallbacks for all of them.

# Google Gemini API — used for AI-powered fact-check explanations
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=

# Google Fact Check Tools API — authoritative claim ratings
# Get yours at: https://console.cloud.google.com/ (enable "Fact Check Tools API")
GOOGLE_FACTCHECK_API_KEY=

# Resend API — for emailing verification reports
# Get yours at: https://resend.com/
RESEND_API_KEY=
